# Copy this file to .env.local and fill in your Supabase credentials
# to enable global online leaderboards.
# Get these from https://supabase.com (free tier)
#
# Required table: leaderboard
# Columns: id (uuid, primary key), name (text), score (int8), date (text)
# RLS: allow anonymous SELECT and INSERT

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON=your-anon-key-here
